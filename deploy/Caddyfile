# deploy/Caddyfile
{$RSSCHAT_DOMAIN} {
	handle /mail* {
		basic_auth {
			{$MAILPIT_USER} {$MAILPIT_PASSWORD_HASH}
		}
		reverse_proxy mailpit:8025
	}

	# Feeds are not here: the app serves them from the database at /users/* and
	# /data/subs.opml, which the default reverse_proxy below already covers.

	handle_path /static/* {
		root * /static
		file_server
	}

	@websockets {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @websockets {
		reverse_proxy rsschat:1462
	}

	handle {
		reverse_proxy rsschat:1452
	}
}
